NODE_ENV=production
PORT=3000
GLOBAL_PREFIX=api
CORS_ORIGINS=https://your-frontend-domain.com
TRUST_PROXY=true
ENABLE_SNAPSHOT=false
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
# Required in production — generate with: openssl rand -hex 32
API_TOKEN=replace-with-64-char-hex-token
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.your-domain.com/v1/traces
LOG_LEVEL=info
CACHE_DEFAULT_TTL_SEC=60
CACHE_MAX_ITEMS=100000
DB_HOST=your-postgres-host
DB_PORT=5432
DB_USERNAME=replace-with-secure-username
DB_PASSWORD=replace-with-strong-password-min-12
DB_NAME=your_database
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA=
DB_RETRY_ATTEMPTS=5
DB_RETRY_DELAY_MS=3000
# Required in production — generate with: openssl rand -hex 32
METRICS_TOKEN=replace-with-64-char-hex-token

# Mail module (required when MAIL_ENABLED=true)
MAIL_ENABLED=true
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=replace-with-smtp-username
MAIL_PASSWORD=replace-with-smtp-password
MAIL_DEFAULT_FROM=no-reply@your-domain.com
MAIL_VERIFY_ON_STARTUP=true
MAIL_POOL=true
MAIL_MAX_CONNECTIONS=10
MAIL_MAX_MESSAGES=200
MAIL_CONNECTION_TIMEOUT_MS=10000
MAIL_GREETING_TIMEOUT_MS=10000
MAIL_SOCKET_TIMEOUT_MS=15000
MAIL_REQUIRE_TLS=true
MAIL_REJECT_UNAUTHORIZED=true
MAIL_QUEUE_ENABLED=true
MAIL_QUEUE_POLL_INTERVAL_MS=1000
MAIL_QUEUE_BATCH_SIZE=50
MAIL_QUEUE_CONCURRENCY=15
MAIL_MAX_ATTEMPTS=5
MAIL_RETRY_BASE_DELAY_MS=15000
MAIL_IDEMPOTENCY_TTL_SEC=86400
MAIL_TEMPLATE_CACHE_TTL_SEC=900
