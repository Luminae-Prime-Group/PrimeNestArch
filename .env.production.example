NODE_ENV=production
PORT=3000
GLOBAL_PREFIX=api
CORS_ORIGINS=https://your-frontend-domain.com
TRUST_PROXY=true
ENABLE_SNAPSHOT=false
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.your-domain.com/v1/traces
LOG_LEVEL=info
DB_HOST=your-postgres-host
DB_PORT=5432
DB_USERNAME=replace-with-secure-username
DB_PASSWORD=replace-with-strong-password-min-12
DB_NAME=your_database
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA=
DB_RETRY_ATTEMPTS=5
DB_RETRY_DELAY_MS=3000
# Required in production — generate with: openssl rand -hex 32
METRICS_TOKEN=replace-with-64-char-hex-token
