NODE_ENV=test
PORT=3000
GLOBAL_PREFIX=api
CORS_ORIGINS=http://localhost:3000
TRUST_PROXY=false
ENABLE_SNAPSHOT=false
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
API_TOKEN=test-api-token-change-me
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=error
CACHE_DEFAULT_TTL_SEC=60
CACHE_MAX_ITEMS=10000
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=postgres_test
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA=
DB_RETRY_ATTEMPTS=1
DB_RETRY_DELAY_MS=500
METRICS_TOKEN=

# Mail module
MAIL_ENABLED=false
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_DEFAULT_FROM=test-no-reply@example.com
MAIL_VERIFY_ON_STARTUP=false
MAIL_POOL=false
MAIL_MAX_CONNECTIONS=1
MAIL_MAX_MESSAGES=20
MAIL_CONNECTION_TIMEOUT_MS=5000
MAIL_GREETING_TIMEOUT_MS=5000
MAIL_SOCKET_TIMEOUT_MS=5000
MAIL_REQUIRE_TLS=false
MAIL_REJECT_UNAUTHORIZED=false
MAIL_QUEUE_ENABLED=true
MAIL_QUEUE_POLL_INTERVAL_MS=500
MAIL_QUEUE_BATCH_SIZE=10
MAIL_QUEUE_CONCURRENCY=2
MAIL_MAX_ATTEMPTS=2
MAIL_RETRY_BASE_DELAY_MS=2000
MAIL_IDEMPOTENCY_TTL_SEC=600
MAIL_TEMPLATE_CACHE_TTL_SEC=120
