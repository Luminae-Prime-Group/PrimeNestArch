NODE_ENV=development
PORT=3000
GLOBAL_PREFIX=api
CORS_ORIGINS=http://localhost:3000
TRUST_PROXY=false
ENABLE_SNAPSHOT=false
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
# Global API token required by all routes (x-api-token or Authorization: Bearer <token>)
API_TOKEN=dev-local-api-token-change-me
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info
CACHE_DEFAULT_TTL_SEC=60
CACHE_MAX_ITEMS=10000
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=postgres
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA=
DB_RETRY_ATTEMPTS=5
DB_RETRY_DELAY_MS=3000
# Protect /metrics — generate with: openssl rand -hex 32
METRICS_TOKEN=

# Mail module
MAIL_ENABLED=false
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_DEFAULT_FROM=no-reply@example.com
MAIL_VERIFY_ON_STARTUP=false
MAIL_POOL=true
MAIL_MAX_CONNECTIONS=5
MAIL_MAX_MESSAGES=100
MAIL_CONNECTION_TIMEOUT_MS=10000
MAIL_GREETING_TIMEOUT_MS=10000
MAIL_SOCKET_TIMEOUT_MS=15000
MAIL_REQUIRE_TLS=true
MAIL_REJECT_UNAUTHORIZED=true
MAIL_QUEUE_ENABLED=true
MAIL_QUEUE_POLL_INTERVAL_MS=1000
MAIL_QUEUE_BATCH_SIZE=20
MAIL_QUEUE_CONCURRENCY=5
MAIL_MAX_ATTEMPTS=3
MAIL_RETRY_BASE_DELAY_MS=10000
MAIL_IDEMPOTENCY_TTL_SEC=3600
MAIL_TEMPLATE_CACHE_TTL_SEC=300
